{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus" },
    { "type": "panel", "id": "stat", "name": "Stat" },
    { "type": "panel", "id": "timeseries", "name": "Time series" },
    { "type": "panel", "id": "bargauge", "name": "Bar gauge" },
    { "type": "panel", "id": "gauge", "name": "Gauge" },
    { "type": "panel", "id": "piechart", "name": "Pie chart" },
    { "type": "panel", "id": "barchart", "name": "Bar chart" }
  ],
  "uid": "usf-overview",
  "title": "USF Platform Overview",
  "tags": ["usf", "overview"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Service Health",
      "type": "stat",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "up{job=~\"usf-.*|opa|redpanda\"}",
          "legendFormat": "{{ job }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      },
      "options": { "graphMode": "none", "colorMode": "background" }
    },
    {
      "id": 2,
      "title": "Query Throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=~\"usf-.*\"}[1m]) * 60",
          "legendFormat": "{{ job }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqpm" } }
    },
    {
      "id": 3,
      "title": "Ingestion Jobs (24h)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "increase(usf_ingestion_jobs_total{status=\"completed\"}[24h])",
          "legendFormat": "completed"
        },
        {
          "expr": "increase(usf_ingestion_jobs_total{status=\"failed\"}[24h])",
          "legendFormat": "failed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": { "orientation": "horizontal", "displayMode": "gradient" }
    },
    {
      "id": 4,
      "title": "KG Triple Count",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "usf_kg_triples_total",
          "legendFormat": "triples"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "graphMode": "area", "colorMode": "value" }
    },
    {
      "id": 5,
      "title": "Cache Hit Rate",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "usf:cache_hit_rate * 100",
          "legendFormat": "hit rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "green", "value": 80 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "ABAC Decisions",
      "type": "piechart",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(usf_abac_decisions_total{decision=\"permit\"})", "legendFormat": "permit" },
        { "expr": "sum(usf_abac_decisions_total{decision=\"deny\"})", "legendFormat": "deny" },
        { "expr": "sum(usf_abac_decisions_total{decision=\"permit_filtered\"})", "legendFormat": "permit-with-filter" }
      ],
      "options": { "pieType": "donut", "legend": { "displayMode": "table", "placement": "right" } }
    },
    {
      "id": 7,
      "title": "Context Usage",
      "type": "barchart",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (context) (usf_queries_total)",
          "legendFormat": "{{ context }}"
        }
      ],
      "options": { "orientation": "horizontal" }
    },
    {
      "id": 8,
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=~\"usf-.*\",status=~\"4..|5..\"}[5m])",
          "legendFormat": "{{ job }} {{ status }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 10 }
        }
      }
    }
  ]
}
