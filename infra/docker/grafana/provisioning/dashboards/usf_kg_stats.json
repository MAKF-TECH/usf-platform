{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus" },
    { "type": "panel", "id": "barchart", "name": "Bar chart" },
    { "type": "panel", "id": "stat", "name": "Stat" },
    { "type": "panel", "id": "piechart", "name": "Pie chart" },
    { "type": "panel", "id": "histogram", "name": "Histogram" },
    { "type": "panel", "id": "timeseries", "name": "Time series" }
  ],
  "uid": "usf-kg-stats",
  "title": "USF Knowledge Graph Stats",
  "tags": ["usf", "knowledge-graph"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Triples per Named Graph",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "usf_kg_triples_by_graph",
          "legendFormat": "{{ graph }}"
        }
      ],
      "options": { "orientation": "horizontal" }
    },
    {
      "id": 2,
      "title": "SHACL Violation Rate",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(usf_shacl_violations_total[5m])",
          "legendFormat": "violations/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": { "graphMode": "area", "colorMode": "background" }
    },
    {
      "id": 3,
      "title": "Entity Resolution: Matches vs New",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(usf_entity_resolution_total{result=\"matched\"})", "legendFormat": "matched" },
        { "expr": "sum(usf_entity_resolution_total{result=\"new\"})", "legendFormat": "new" }
      ],
      "options": { "pieType": "donut", "legend": { "displayMode": "table", "placement": "right" } }
    },
    {
      "id": 4,
      "title": "LangExtract Confidence Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "usf_langextract_confidence_bucket",
          "legendFormat": "{{ le }}",
          "format": "heatmap"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "bucketSize": 0.1 }
    },
    {
      "id": 5,
      "title": "Query Latency p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=~\"usf-.*\"}[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=~\"usf-.*\"}[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=~\"usf-.*\"}[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } } }
    }
  ]
}
