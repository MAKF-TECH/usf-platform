# USF Platform — Environment Variables
# Copy to .env and fill in values for your environment.
# NEVER commit real secrets. Use a secrets manager in production.

# ─── GENERAL ─────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_JSON=false

# ─── DATABASE ────────────────────────────────────────────────
POSTGRES_USER=usf_app
POSTGRES_PASSWORD=changeme
POSTGRES_DB=usf
DATABASE_URL=postgresql+psycopg://usf_app:changeme@postgres:5432/usf

# ─── VALKEY / REDIS ──────────────────────────────────────────
VALKEY_URL=redis://valkey:6379/0

# ─── REDPANDA / KAFKA ────────────────────────────────────────
REDPANDA_BOOTSTRAP=redpanda:9092

# ─── QLEVER ──────────────────────────────────────────────────
QLEVER_SPARQL_ENDPOINT=http://qlever:7001/sparql
QLEVER_UPDATE_ENDPOINT=http://qlever:7001/update

# ─── ARCADEDB ────────────────────────────────────────────────
ARCADEDB_URL=http://arcadedb:2480
ARCADEDB_DATABASE=usf
ARCADEDB_USER=root
ARCADEDB_PASSWORD=changeme

# ─── ONTOP ───────────────────────────────────────────────────
ONTOP_SPARQL_ENDPOINT=http://ontop:8080/sparql

# ─── WREN ENGINE ─────────────────────────────────────────────
WREN_ENGINE_URL=http://wren-engine:8080

# ─── OPA ─────────────────────────────────────────────────────
OPA_URL=http://opa:8181

# ─── API AUTH (JWT) ──────────────────────────────────────────
JWT_SECRET=dev_jwt_secret_change_in_production
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem

# ─── AI / LLM ───────────────────────────────────────────────
LLM_PROVIDER=google
LLM_MODEL=gemini-1.5-pro
OPENAI_API_KEY=
LLM_API_KEY=

# ─── SERVICE URLS ────────────────────────────────────────────
QUERY_SERVICE_URL=http://usf-query:8001
KG_SERVICE_URL=http://usf-kg:8002
SDL_SERVICE_URL=http://usf-sdl:8004
AUDIT_SERVICE_URL=http://usf-audit:8006
API_SERVICE_URL=http://usf-api:8000

# ─── CELERY ──────────────────────────────────────────────────
CELERY_BROKER_URL=redis://valkey:6379/1
CELERY_RESULT_BACKEND=db+postgresql+psycopg://usf_app:changeme@postgres:5432/usf

# ─── INGEST ──────────────────────────────────────────────────
DOCLING_DEVICE=cpu

# ─── SDL ─────────────────────────────────────────────────────
SDL_STORAGE_PATH=/data/sdl

# ─── MCP ─────────────────────────────────────────────────────
MCP_PORT=8005
MCP_TRANSPORT=sse

# ─── AUDIT ───────────────────────────────────────────────────
AUDIT_RETENTION_YEARS=7
EXPORT_STORAGE_PATH=/data/audit-exports

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:4200"]

# ─── NL2SPARQL ───────────────────────────────────────────────
NL2SPARQL_MAX_ITERATIONS=3

# ─── PYOXIGRAPH ──────────────────────────────────────────────
PYOXIGRAPH_STORE_PATH=/data/pyoxigraph

# ─── OBSERVABILITY ───────────────────────────────────────────
GRAFANA_PASSWORD=admin
