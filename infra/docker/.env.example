# USF Platform — Environment Variables
# Copy to .env and fill in values for your environment.
# NEVER commit real secrets. Use a secrets manager in production.

# ─── DATABASE ────────────────────────────────────────────────
# PostgreSQL password for the usf user
POSTGRES_PASSWORD=usf_dev_password

# ─── ARCADEDB ────────────────────────────────────────────────
# ArcadeDB root password
ARCADEDB_ROOT_PASSWORD=usf_dev_password

# ─── API AUTH ────────────────────────────────────────────────
# JWT signing secret — CHANGE THIS IN PRODUCTION (use openssl rand -hex 32)
JWT_SECRET=dev_jwt_secret_change_in_production

# ─── AI / LLM ────────────────────────────────────────────────
# OpenAI API key (required for NLP/embedding features in usf-query and usf-ingest)
# Leave empty to disable LLM features in local dev
OPENAI_API_KEY=

# ─── OBSERVABILITY ───────────────────────────────────────────
# Grafana admin password
GRAFANA_PASSWORD=admin
